#!/usr/bin/env bash
set -euo pipefail

# ── helpers ───────────────────────────────────────────────────────────────────

die() { printf 'wt-activate-init: error: %s\n' "$*" >&2; exit 1; }
info() { printf '%s\n' "$*"; }

# ── locate git context ────────────────────────────────────────────────────────

if ! git rev-parse --git-dir &>/dev/null; then
  die "not inside a git repository"
fi

GIT_COMMON="$(git rev-parse --git-common-dir)" \
  || die "could not determine git common dir"

CONFIG_FILE="${GIT_COMMON}/wt-activate"

# ── warn if already initialized ───────────────────────────────────────────────

if [[ -f "$CONFIG_FILE" ]]; then
  info "Config already exists at: ${CONFIG_FILE}"
  info "Current contents:"
  cat "$CONFIG_FILE"
  printf '\nOverwrite? [y/N] '
  read -r CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }
fi

# ── compute a sensible default ────────────────────────────────────────────────

# Resolve the real path to the common dir
COMMON_REALPATH="$(cd "$GIT_COMMON" && pwd -P)"

# If the common dir is named ".git", the repo dir is its parent (standard repo)
# Otherwise it's a bare repo, and the common dir IS the repo dir
if [[ "$(basename "$COMMON_REALPATH")" == ".git" ]]; then
  REPO_DIR="$(dirname "$COMMON_REALPATH")"
else
  REPO_DIR="$COMMON_REALPATH"
fi

CONTAINER_DIR="$(dirname "$REPO_DIR")"
DEFAULT_LINK="${CONTAINER_DIR}/active"

# ── prompt ────────────────────────────────────────────────────────────────────

info ""
info "wt-activate-init"
info "  Git common dir : ${GIT_COMMON}"
info "  Config file    : ${CONFIG_FILE}"
info ""
info "Enter the path where the 'active' symlink should be created."
printf "  [default: %s]: " "$DEFAULT_LINK"
read -r USER_INPUT

if [[ -z "$USER_INPUT" ]]; then
  ACTIVE_LINK="$DEFAULT_LINK"
else
  # Expand ~ to $HOME if the user typed it
  ACTIVE_LINK="${USER_INPUT/#\~/$HOME}"
fi

# ── warn if parent doesn't exist ─────────────────────────────────────────────

LINK_PARENT="$(dirname "$ACTIVE_LINK")"
if [[ ! -d "$LINK_PARENT" ]]; then
  info ""
  info "Warning: parent directory does not exist yet: ${LINK_PARENT}"
  info "It must exist before running wt-activate."
fi

# ── write config ──────────────────────────────────────────────────────────────

{
  printf '# wt-activate config\n'
  printf '# Generated by wt-activate-init on %s\n' "$(date +%Y-%m-%d)"
  printf 'ACTIVE_LINK=%s\n' "$ACTIVE_LINK"
} > "$CONFIG_FILE"

info ""
info "Config written to: ${CONFIG_FILE}"
info "  ACTIVE_LINK=${ACTIVE_LINK}"
info ""
info "Run 'wt-activate' from any worktree to activate it."
